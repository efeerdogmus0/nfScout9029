# Domain where app will be served (required by Caddy TLS)
DOMAIN=scout.example.com

# Postgres
POSTGRES_DB=nfscout
POSTGRES_USER=nfscout
POSTGRES_PASSWORD=change-me-strong

# External API keys
TBA_API_KEY=
OPENROUTER_API_KEY=

# Optional OpenRouter settings
OPENROUTER_MODEL=x-ai/grok-4-fast
OPENROUTER_HTTP_REFERER=https://scout.example.com
OPENROUTER_APP_TITLE=NF Scout 9029
