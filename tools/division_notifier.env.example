# Optional if backend/.env already has TBA_API_KEY.
# If set here, this value takes priority.
# TBA_API_KEY=your_tba_key_here

# Team to watch (frc9029 or 9029)
MY_TEAM=frc9029

# Comma-separated division event keys to probe.
# Replace with your season's championship division event keys.
# Example placeholders:
DIVISION_EVENT_KEYS=2026gal,2026new,2026hop,2026arc,2026cur,2026car,2026tes,2026dal

# Poll interval (seconds). 600 = 10 minutes.
POLL_SECONDS=600

# Optional
OPEN_URL_ON_ALERT=true
ALERT_URL=http://localhost:5173
