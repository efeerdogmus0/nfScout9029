# ─── Backend Ortam Değişkenleri ───────────────────────────────────────────────
# Bu dosyayı kopyalayın: cp .env.example backend/.env
# Backend'i bu dosyanın bulunduğu dizinden başlatın.

# ── Veritabanı ────────────────────────────────────────────────────────────────
# Geliştirme için SQLite (varsayılan — herhangi bir değişiklik gerekmez):
# DATABASE_URL=sqlite+pysqlite:///./rebuilt.db

# Üretim için PostgreSQL:
# DATABASE_URL=postgresql+psycopg://kullanici:sifre@localhost:5432/nfscout
DATABASE_URL=sqlite+pysqlite:///./rebuilt.db

# ── Sunucu ────────────────────────────────────────────────────────────────────
# Frontend http://localhost:8001 beklediği için bu portu kullanın.
# uvicorn app.main:app --reload --port 8001
PORT=8001

# ── API anahtarları (Git'e koymayın) ──────────────────────────────────────────
# The Blue Alliance (backend fallback key)
TBA_API_KEY=

# OpenRouter (War Room AI + Team Profile AI özetleri)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=x-ai/grok-4-fast

# OpenRouter zorunlu metadata başlıkları
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=FRC REBUILT Scouting
